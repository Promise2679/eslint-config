{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major deps"
    },
    {
      "matchDepTypes": ["action"],
      "pinDigests": false
    }
  ],
  "postUpdateOptions": ["pnpmDedupe"],
  "labels": ["automated-pr"]
}
